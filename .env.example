# ─── Qdrant ───────────────────────────────────────────────────────────────────
# For local Docker: leave QDRANT_API_KEY empty
# For Qdrant Cloud: set QDRANT_HOST to your cluster URL and add API key
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_API_KEY=

# ─── Collection ───────────────────────────────────────────────────────────────
COLLECTION_NAME=news_embeddings
TOP_K=50

# ─── Model ────────────────────────────────────────────────────────────────────
MODEL_NAME=BAAI/bge-m3
# Path to save/load ranker weights (relative to project root)
RANKER_WEIGHTS_PATH=ranker_weights.pt

# ─── Local SQLite Store ────────────────────────────────────────────────────────
# Path to the SQLite database file (relative to project root)
SQLITE_DB_PATH=local_store/news.db

# ─── Embedding Cache ──────────────────────────────────────────────────────────
# Max number of user-query embeddings to cache in memory
CACHE_MAX_SIZE=1000

# ─── Ingestion ────────────────────────────────────────────────────────────────
# Path to the source CSV dataset
DATASET_PATH=news_dataset.csv
# Batch size for embedding during ingestion
INGEST_BATCH_SIZE=32
