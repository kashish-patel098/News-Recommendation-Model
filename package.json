{
  "name": "news-recommendation",
  "version": "2.0.0",
  "private": true,
  "type": "module",
  "description": "News Recommendation API — reads from existing Qdrant",
  "scripts": {
    "start":       "pm2 start ecosystem.config.cjs",
    "stop":        "pm2 stop news-rec-api",
    "restart":     "pm2 restart news-rec-api",
    "reload":      "pm2 reload news-rec-api",
    "delete":      "pm2 delete news-rec-api",
    "status":      "pm2 status",
    "logs":        "pm2 logs news-rec-api",
    "dev":         "bash start.sh --dev",

    "train":       "venv/bin/python scripts/monthly_train.py",
    "train:all":   "venv/bin/python scripts/monthly_train.py --all-data"
  },
  "dependencies": {
    "dotenv": "^16.4.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
