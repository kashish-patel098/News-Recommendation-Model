{
  "name": "news-recommendation",
  "version": "2.0.0",
  "private": true,
  "type": "module",
  "description": "News Recommendation API — reads from existing Qdrant",
  "scripts": {
    "start":       "bash start.sh --dev",
    "stop":        "pm2 stop news-rec-api",
    "restart":     "pm2 restart news-rec-api",
    "reload":      "pm2 reload news-rec-api",
    "delete":      "pm2 delete news-rec-api",
    "status":      "pm2 status",
    "logs":        "pm2 logs news-rec-api",
    "dev":         "bash start.sh --dev",

    "train":       ".venv/bin/python3 scripts/monthly_train.py",
    "train:all":   ".venv/bin/python3 scripts/monthly_train.py --all-data",
    "train:10k":   ".venv/bin/python3 scripts/monthly_train.py --all-data --max-articles 10000 --pairs 40000 --epochs 3"
  },
  "dependencies": {
    "dotenv": "^16.4.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
