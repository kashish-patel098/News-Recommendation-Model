# ─── EC2 Environment Variables — News Recommendation API ─────────────────────
# Copy to .env and fill in your real values before deploying.
#
#   cp .env.ec2.example .env
#   nano .env
#
# AWS credentials are NOT needed.
# The EC2 IAM Instance Role gives automatic access to Athena + S3.
# ─────────────────────────────────────────────────────────────────────────────

# ─── API port ─────────────────────────────────────────────────────────────────
PORT=8000

# ─── AWS Region (IAM Instance Role used — no keys needed) ────────────────────
AWS_REGION=us-east-1

# ─── Qdrant (read-only — already populated by your vector pipeline) ───────────
QDRANT_HOST=http://localhost
QDRANT_PORT=6333
QDRANT_API_KEY=

# ─── Collection ───────────────────────────────────────────────────────────────
COLLECTION_NAME=news_embeddings
TOP_K=50

# ─── Vector size ──────────────────────────────────────────────────────────────
# all-MiniLM-L6-v2 = 384-dim natively.
# Must match the dimension used when your Qdrant collection was created.
VECTOR_SIZE=384

# ─── Embedding Model ──────────────────────────────────────────────────────────
# You can use the Xenova/ prefix — it is automatically resolved to the
# equivalent PyTorch HuggingFace model at runtime (same weights, same output).
#   Xenova/all-MiniLM-L6-v2  →  sentence-transformers/all-MiniLM-L6-v2 (384-dim)
#   Xenova/bge-base-en-v1.5  →  BAAI/bge-base-en-v1.5                   (768-dim)
MODEL_NAME=Xenova/all-MiniLM-L6-v2
RANKER_WEIGHTS_PATH=ranker_weights.pt

# ─── Athena / Iceberg (sole data store — no PostgreSQL) ──────────────────────
# IAM Instance Role provides access automatically — no keys needed.
ATHENA_DATABASE=news_db
ATHENA_TABLE=news_articles
ATHENA_OUTPUT_BUCKET=s3://your-bucket/athena-results/

# ─── Cache ────────────────────────────────────────────────────────────────────
CACHE_MAX_SIZE=1000
INGEST_BATCH_SIZE=16
