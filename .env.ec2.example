# ─── EC2 Environment Variables — News Recommendation API ─────────────────────
# This project only runs the FastAPI recommendation API.
# Qdrant is already populated by your separate vector pipeline.
#
#   cp .env.ec2.example .env
#   nano .env
#
# AWS credentials are NOT needed.
# The EC2 IAM Instance Role gives automatic access to Athena + S3.
# ─────────────────────────────────────────────────────────────────────────────

# ─── API port ─────────────────────────────────────────────────────────────────
PORT=8000

# ─── AWS Region (IAM Instance Role used — no keys needed) ────────────────────
AWS_REGION=us-east-1

# ─── Qdrant (read-only — already populated by your vector pipeline) ───────────
QDRANT_HOST=http://localhost
QDRANT_PORT=6333
QDRANT_API_KEY=

# ─── Collection ───────────────────────────────────────────────────────────────
COLLECTION_NAME=news_embeddings
TOP_K=50

# ─── Vector size (must match existing Qdrant collection) ─────────────────────
VECTOR_SIZE=386

# ─── Embedding Model ──────────────────────────────────────────────────────────
MODEL_NAME=BAAI/bge-m3
RANKER_WEIGHTS_PATH=ranker_weights.pt

# ─── PostgreSQL (full article content store) ──────────────────────────────────
DATABASE_URL=postgresql://dbuser:dbpassword@your-rds-endpoint:5432/newsdb

# ─── Athena / Iceberg (used by monthly_train.py to pull training data) ────────
ATHENA_DATABASE=news_db
ATHENA_TABLE=news_articles
ATHENA_OUTPUT_BUCKET=s3://your-bucket/athena-results/

# ─── Cache ────────────────────────────────────────────────────────────────────
CACHE_MAX_SIZE=1000
INGEST_BATCH_SIZE=16
