# ─── EC2 Environment Variables — News Recommendation Engine ──────────────────
# Copy to .env and fill in your real values before deploying.
#
#   cp .env.ec2.example .env
#   nano .env
#
# ─────────────────────────────────────────────────────────────────────────────
# THREE SERVICES run on EC2:
#   1. FastAPI backend    (Python / uvicorn)       → PORT 8000
#   2. Vector orchestrator (Node.js / index.js)   → hourly S3→Qdrant job
#   3. Next.js frontend                           → FRONTEND_PORT 3000
# ─────────────────────────────────────────────────────────────────────────────

# ─── Server ports ─────────────────────────────────────────────────────────────
PORT=8000
FRONTEND_PORT=3000

# ─── Qdrant ───────────────────────────────────────────────────────────────────
# Used by BOTH Python backend AND Node.js vector orchestrator
QDRANT_HOST=http://localhost
QDRANT_PORT=6333
QDRANT_API_KEY=
# Used directly by Node.js (full URL form)
QDRANT_URL=http://localhost:6333

# ─── Collection ───────────────────────────────────────────────────────────────
COLLECTION_NAME=news_embeddings
COLLECTION=news_embeddings
TOP_K=50

# ─── Vector size (must match Qdrant collection: title/description/tags) ───────
VECTOR_SIZE=386

# ─── Node.js vector orchestrator (index.js + ec2_vector.js) ──────────────────
# URL of the FastAPI /embed endpoint — reuses the already-loaded BGE-m3 model
EMBED_API_URL=http://localhost:8000

# S3 bucket where hourly Economic Times JSON files are stored
S3_BUCKET=your-news-bucket
S3_REGION=us-east-1

# How often (ms) to run the vector job. Default: 1 hour = 3600000
VECTOR_JOB_INTERVAL_MS=3600000

# ─── Embedding Model (Python FastAPI side) ────────────────────────────────────
MODEL_NAME=BAAI/bge-m3
RANKER_WEIGHTS_PATH=ranker_weights.pt

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://dbuser:dbpassword@your-rds-endpoint:5432/newsdb

# ─── AWS ──────────────────────────────────────────────────────────────────────
# Leave empty if using an EC2 IAM Instance Role (recommended — no hardcoded keys)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ─── Athena / Iceberg (used by monthly_train.py) ──────────────────────────────
ATHENA_DATABASE=news_db
ATHENA_TABLE=news_articles
ATHENA_OUTPUT_BUCKET=s3://your-bucket/athena-results/

# ─── Ingestion ────────────────────────────────────────────────────────────────
INGEST_BATCH_SIZE=16

# ─── Embedding Cache ──────────────────────────────────────────────────────────
CACHE_MAX_SIZE=1000
